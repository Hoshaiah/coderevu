# ---------- Public ----------
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# ---------- Database ----------
# Local dev (non-Docker): point at your own Postgres.
# Inside docker compose, the app reads DATABASE_URL from compose's
# environment (postgres://...@postgres:5432/coderevu) and ignores this
# value. The Postgres service reads POSTGRES_USER/POSTGRES_PASSWORD/
# POSTGRES_DB below.
DATABASE_URL="postgres://coderevu:coderevu@localhost:5433/coderevu"

POSTGRES_USER=coderevu
POSTGRES_PASSWORD=coderevu
POSTGRES_DB=coderevu

# ---------- AI ----------
# Optional. Without it, the AI tutor panel shows a "set ANTHROPIC_API_KEY
# in .env to enable" message and the chat endpoint returns 503. Everything
# else (problems, drafts, progress) works without a key.
ANTHROPIC_API_KEY=
